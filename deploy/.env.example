SELF_HOSTED=true
POSTGRES_PASSWORD=changeme
# Required. 32-byte hex key for encrypting device tokens at rest.
# Generate with: openssl rand -hex 32
RELAY_ENCRYPTION_KEY=
# Per-household blob quota (default: unlimited in self-hosted mode).
# Accepts human-readable sizes: 5GB, 500MB, 1GiB, etc.
# BLOB_QUOTA=0
# sslmode=disable is safe within the Docker network. If Postgres is
# reachable over an untrusted network, use sslmode=require or higher.
#
# Uncomment for TLS via Caddy (REQUIRED when using docker-compose.caddy.yml):
# DOMAIN=sync.example.com
