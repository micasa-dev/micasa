SELF_HOSTED=true
POSTGRES_PASSWORD=changeme
# Per-household blob quota in bytes (default: unlimited in self-hosted mode):
# BLOB_QUOTA_BYTES=0
# sslmode=disable is safe within the Docker network. If Postgres is
# reachable over an untrusted network, use sslmode=require or higher.
#
# Uncomment for TLS via Caddy (REQUIRED when using docker-compose.caddy.yml):
# DOMAIN=sync.example.com
